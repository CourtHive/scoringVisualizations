{
  "name": "@tennisvisuals/scoring-visualizations",
  "version": "0.2.1",
  "description": "Standalone scoring visualizations for tennis match data — episode transforms, D3 charts (GameTree, Momentum, PTS, GameFish, Corona)",
  "type": "module",
  "main": "dist/scoring-visualizations.es.js",
  "module": "dist/scoring-visualizations.es.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/scoring-visualizations.es.js",
      "require": "./dist/scoring-visualizations.umd.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "build:types": "tsc --emitDeclarationOnly",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prerelease": "pnpm lint && pnpm test && pnpm build && pnpm build-storybook",
    "release": "pnpm prerelease && pnpm version"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/CourtHive/scoringVisualizations.git"
  },
  "keywords": [
    "tennis",
    "scoring",
    "visualizations",
    "d3",
    "game-tree",
    "momentum"
  ],
  "packageManager": "pnpm@10.33.2",
  "license": "MIT",
  "dependencies": {
    "d3": "^7.9.0",
    "tippy.js": "^6.3.7",
    "tods-competition-factory": "^3.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@storybook/addon-docs": "^10.2.9",
    "@storybook/addon-links": "^10.2.9",
    "@storybook/html-vite": "^10.2.9",
    "@types/d3": "^7.4.3",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.1.0",
    "eslint-plugin-sonarjs": "^4.0.2",
    "globals": "^17.3.0",
    "storybook": "^10.2.9",
    "typescript": "^6.0.2",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^5.0.0",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "tods-competition-factory": ">=2.0.0"
  },
  "pnpm": {
    "overrides": {
      "tods-competition-factory": "link:../factory"
    }
  }
}
