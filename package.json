{
  "name": "@tennisvisuals/scoring-visualizations",
  "version": "0.2.1",
  "description": "Standalone scoring visualizations for tennis match data — episode transforms, D3 charts (GameTree, Momentum, PTS, GameFish, Corona)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prerelease": "pnpm lint && pnpm test && pnpm build && pnpm build-storybook",
    "release": "pnpm prerelease && pnpm version"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/TennisVisuals/scoringVisualizations.git"
  },
  "keywords": [
    "tennis",
    "scoring",
    "visualizations",
    "d3",
    "game-tree",
    "momentum"
  ],
  "packageManager": "pnpm@10.30.0",
  "license": "MIT",
  "dependencies": {
    "d3": "^7.9.0",
    "tippy.js": "^6.3.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@storybook/addon-docs": "^10.2.9",
    "@storybook/addon-links": "^10.2.9",
    "@storybook/html-vite": "^10.2.9",
    "@types/d3": "^7.4.3",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "eslint": "^9.39.2",
    "eslint-plugin-sonarjs": "^3.0.7",
    "globals": "^17.3.0",
    "storybook": "^10.2.9",
    "tods-competition-factory": "2.4.5",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "tods-competition-factory": ">=2.0.0"
  }
}
